<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sistema de Reservas</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    @* Google Fonts para un look más moderno *@
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        :root {
            /* PALETA CLARA: Soft White & Sky Blue */
            --primary-light: #f0f4f8; /* Fondo general muy claro */
            --accent-blue: #0ea5e9; /* Azul cielo vibrante para botones */
            --text-main: #1e293b; /* Gris oscuro para texto */
            --glass-bg: #ffffff; /* Blanco puro para las tarjetas */
            --glass-border: rgba(14, 165, 233, 0.1);
        }

        body {
            background-color: var(--primary-light);
            /* Degradado muy suave y luminoso */
            background-image: radial-gradient(at 0% 0%, rgba(14, 165, 233, 0.05) 0px, transparent 50%), radial-gradient(at 100% 0%, rgba(255, 255, 255, 0.8) 0px, transparent 50%);
            font-family: 'Plus Jakarta Sans', sans-serif;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            color: var(--text-main);
        }

        /* Navbar Blanca y Elegante */
        .navbar {
            background: rgba(255, 255, 255, 0.9) !important;
            backdrop-filter: blur(10px);
            margin: 20px auto;
            width: 92%;
            border-radius: 16px;
            border: 1px solid rgba(0,0,0,0.05);
            padding: 12px 25px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03);
        }

        .navbar-brand {
            font-weight: 800;
            color: var(--text-main) !important;
            background: linear-gradient(to right, #0ea5e9, #6366f1);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            letter-spacing: -0.5px;
        }

        .nav-link {
            color: #64748b !important;
            font-weight: 600;
            transition: all 0.2s ease;
        }

            .nav-link:hover {
                color: var(--accent-blue) !important;
            }

        /* La Tarjeta Central: Ahora es la protagonista */
        .main-card {
            background: var(--glass-bg);
            border-radius: 32px;
            padding: 45px;
            margin-top: 10px;
            margin-bottom: 60px;
            /* Sombra muy suave para que parezca que flota */
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.06);
            color: var(--text-main);
            border: 1px solid rgba(0,0,0,0.02);
            min-height: 70vh;
        }

        footer {
            background: #ffffff;
            padding: 30px 0;
            border-top: 1px solid rgba(0,0,0,0.05);
            color: #94a3b8;
        }

        /* Estado del usuario en colores claros */
        .user-status {
            background: #f1f5f9;
            color: #475569;
            padding: 6px 16px;
            border-radius: 10px;
            border: 1px solid #e2e8f0;
            font-size: 0.8rem;
            font-weight: 600;
        }

        /* Botón de Reportes más suave */
        .btn-admin {
            background: #0ea5e9;
            color: white !important;
            font-weight: 600;
            border-radius: 12px;
            border: none;
            box-shadow: 0 4px 12px rgba(14, 165, 233, 0.2);
        }

            .btn-admin:hover {
                background: #0284c7;
                transform: translateY(-1px);
                box-shadow: 0 6px 15px rgba(14, 165, 233, 0.3);
            }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light sticky-top">
            <div class="container-fluid">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-stars me-2"></i>SISTEMA DE RESERVAS
                </a>

                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="bi bi-list fs-2 text-dark"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door-fill me-1"></i>Inicio
                            </a>
                        </li>

                        @* OPCIÓN PARA TODOS: Explorar Hoteles *@
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Hotels" asp-action="Index">
                                <i class="bi bi-building-fill me-1"></i>Explorar Hoteles
                            </a>
                        </li>

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Reservas" asp-action="Index">
                                    <i class="bi bi-calendar-check-fill me-1"></i>Mis Reservas
                                </a>
                            </li>

                            @if (User.IsInRole("Administrador"))
                            {
                                <li class="nav-item ms-lg-2">
                                    <a class="nav-link btn-admin px-3 text-white" asp-controller="Reservas" asp-action="Reporte">
                                        <i class="bi bi-file-earmark-pdf me-1"></i>Reportes
                                    </a>
                                </li>
                            }
                        }
                    </ul>

                    <div class="d-flex align-items-center gap-3">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <div class="user-status d-none d-md-inline-flex">
                                <span class="me-2"><i class="bi bi-circle-fill" style="font-size: 8px; color: #10b981;"></i></span>
                                @User.Identity.Name
                            </div>
                        }
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container page-transition">
        <main role="main" class="main-card">
            @RenderBody()
        </main>
    </div>

    <footer class="footer">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6 text-md-start mb-3 mb-md-0">
                    <p class="mb-0 opacity-50 small text-muted">
                        &copy; 2026 - <span class="text-info">Informatica y Sistemas</span> - Univalle
                    </p>
                </div>
                <div class="col-md-6 text-md-end">
                    <div class="d-flex justify-content-md-end gap-3 text-secondary">
                        <i class="bi bi-facebook pointer"></i>
                        <i class="bi bi-instagram pointer"></i>
                        <i class="bi bi-shield-check pointer"></i>
                    </div>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>