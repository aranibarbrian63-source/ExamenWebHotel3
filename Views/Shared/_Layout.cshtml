<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Luxury Premium Reservations</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    @* Google Fonts para un look más moderno *@
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        :root {
            --primary-dark: #0f172a;
            --accent-blue: #38bdf8;
            --glass-bg: rgba(255, 255, 255, 0.95);
            --glass-border: rgba(255, 255, 255, 0.2);
        }

        body {
            background-color: var(--primary-dark);
            background-image: radial-gradient(at 0% 0%, rgba(56, 189, 248, 0.15) 0px, transparent 50%), radial-gradient(at 100% 0%, rgba(59, 130, 246, 0.15) 0px, transparent 50%), radial-gradient(at 100% 100%, rgba(37, 99, 235, 0.15) 0px, transparent 50%), radial-gradient(at 0% 100%, rgba(29, 78, 216, 0.15) 0px, transparent 50%);
            font-family: 'Plus Jakarta Sans', sans-serif;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            color: #f8fafc;
        }

        .navbar {
            background: rgba(15, 23, 42, 0.8) !important;
            backdrop-filter: blur(12px) saturate(180%);
            margin: 15px auto;
            width: 95%;
            border-radius: 20px;
            border: 1px solid var(--glass-border);
            padding: 12px 25px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        }

        .navbar-brand {
            font-weight: 800;
            font-size: 1.4rem;
            background: linear-gradient(to right, #38bdf8, #818cf8);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            letter-spacing: -1px;
        }

        .nav-link {
            color: #94a3b8 !important;
            font-weight: 600;
            padding: 8px 16px !important;
            border-radius: 10px;
            transition: all 0.3s ease;
        }

            .nav-link:hover {
                color: #fff !important;
                background: rgba(56, 189, 248, 0.1);
            }

        .active-link {
            color: var(--accent-blue) !important;
            background: rgba(56, 189, 248, 0.1);
        }

        .main-card {
            background: var(--glass-bg);
            backdrop-filter: blur(16px);
            border-radius: 30px;
            padding: 40px;
            margin-top: 20px; /* Espacio para que no pegue al navbar */
            margin-bottom: 50px;
            border: 1px solid rgba(255, 255, 255, 0.4);
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            color: #1e293b; /* Texto oscuro para que se lea en fondo blanco */
            min-height: 75vh;
        }

        footer {
            background: rgba(15, 23, 42, 0.9);
            padding: 30px 0;
            margin-top: auto;
            border-top: 1px solid var(--glass-border);
            text-align: center;
        }

        .user-status {
            background: rgba(56, 189, 248, 0.15);
            color: var(--accent-blue);
            padding: 6px 18px;
            border-radius: 100px;
            border: 1px solid rgba(56, 189, 248, 0.3);
            font-size: 0.8rem;
            font-weight: 700;
            display: inline-flex;
            align-items: center;
        }

        .btn-admin {
            background: linear-gradient(45deg, #3b82f6, #2563eb);
            color: white !important;
            border-radius: 12px;
            box-shadow: 0 4px 12px rgba(37, 99, 235, 0.3);
        }

        .page-transition {
            animation: fadeInUp 0.6s ease-out;
        }

        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark sticky-top">
            <div class="container-fluid">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-stars me-2"></i>LUXURY HOTEL
                </a>

                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="bi bi-list fs-2 text-white"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door-fill me-1"></i>Inicio
                            </a>
                        </li>

                        @* OPCIÓN PARA TODOS: Explorar Hoteles *@
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Hotels" asp-action="Index">
                                <i class="bi bi-building-fill me-1"></i>Explorar Hoteles
                            </a>
                        </li>

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Reservas" asp-action="Index">
                                    <i class="bi bi-calendar-check-fill me-1"></i>Mis Reservas
                                </a>
                            </li>

                            @if (User.IsInRole("Administrador"))
                            {
                                <li class="nav-item ms-lg-2">
                                    <a class="nav-link btn-admin px-3 text-white" asp-controller="Reservas" asp-action="Reporte">
                                        <i class="bi bi-file-earmark-pdf me-1"></i>Reportes
                                    </a>
                                </li>
                            }
                        }
                    </ul>

                    <div class="d-flex align-items-center gap-3">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <div class="user-status d-none d-md-inline-flex">
                                <span class="me-2"><i class="bi bi-circle-fill" style="font-size: 8px; color: #10b981;"></i></span>
                                @User.Identity.Name
                            </div>
                        }
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container page-transition">
        <main role="main" class="main-card">
            @RenderBody()
        </main>
    </div>

    <footer class="footer">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6 text-md-start mb-3 mb-md-0">
                    <p class="mb-0 opacity-50 small text-white">
                        &copy; 2026 - <span class="text-info">Informatica y Sistemas</span> - Univalle
                    </p>
                </div>
                <div class="col-md-6 text-md-end">
                    <div class="d-flex justify-content-md-end gap-3 text-white-50">
                        <i class="bi bi-facebook pointer"></i>
                        <i class="bi bi-instagram pointer"></i>
                        <i class="bi bi-shield-check pointer"></i>
                    </div>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>