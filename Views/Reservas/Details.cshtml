@model examenwed3.Models.Reserva

@{
    ViewData["Title"] = "Detalle de Reserva";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    body {
        background-color: #f4f7f6;
    }

    .details-container {
        animation: fadeInScale 0.5s ease-out;
        max-width: 700px;
    }

    @@keyframes fadeInScale {
        from {
            opacity: 0;
            transform: scale(0.95);
        }

        to {
            opacity: 1;
            transform: scale(1);
        }
    }

    .ticket-card {
        border: none;
        border-radius: 30px;
        background: white;
        overflow: hidden;
        box-shadow: 0 20px 40px rgba(0,0,0,0.08);
    }

    .ticket-header {
        background: linear-gradient(135deg, #003366 0%, #0056b3 100%);
        color: white;
        padding: 30px;
        text-align: center;
    }

    .info-label {
        font-weight: 700;
        color: #6c757d;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 1px;
    }

    .info-value {
        color: #003366;
        font-weight: 600;
        font-size: 1.1rem;
    }

    .divider-dashed {
        border-top: 2px dashed #e9ecef;
        margin: 20px 0;
        position: relative;
    }

        /* Efecto de "agujeros" de ticket a los lados */
        .divider-dashed::before, .divider-dashed::after {
            content: '';
            position: absolute;
            width: 20px;
            height: 20px;
            background: #f4f7f6;
            border-radius: 50%;
            top: -11px;
        }

        .divider-dashed::before {
            left: -40px;
        }

        .divider-dashed::after {
            right: -40px;
        }

    .btn-custom {
        border-radius: 15px;
        padding: 10px 25px;
        font-weight: 600;
        transition: 0.3s;
    }
</style>

<div class="container details-container py-5">
    <div class="ticket-card">
        <div class="ticket-header">
            <i class="bi bi-check-circle-fill fs-1 mb-2"></i>
            <h3 class="fw-bold mb-0">Reserva Confirmada</h3>
            <p class="opacity-75 mb-0 small">ID de Seguimiento: #@Model.Id</p>
        </div>

        <div class="card-body p-5">
            <div class="row mb-4">
                <div class="col-sm-6 mb-3 mb-sm-0">
                    <p class="info-label mb-1">Hotel</p>
                    <p class="info-value mb-0">
                        <i class="bi bi-building text-primary me-2"></i>
                        @(Model.Hotel?.Nombre ?? "No especificado")
                    </p>
                    <small class="text-muted">
                        <i class="bi bi-geo-alt me-1"></i> @(Model.Hotel?.Direccion ?? "Sin dirección")
                    </small>
                </div>
                <div class="col-sm-6 text-sm-end">
                    <p class="info-label mb-1">Huésped</p>
                    <p class="info-value mb-0">
                        <i class="bi bi-person-badge text-primary me-2"></i>
                        Usuario: @(Model.Usuario?.UserName ?? Model.UsuarioId)
                    </p>
                </div>
            </div>

            <div class="divider-dashed"></div>

            <div class="row text-center py-3">
                <div class="col-5">
                    <p class="info-label mb-2">Check-In</p>
                    <div class="p-3 bg-light rounded-4">
                        <i class="bi bi-calendar-event text-primary d-block mb-1"></i>
                        <span class="info-value">@Model.FechaInicio.ToString("dd MMM, yyyy")</span>
                    </div>
                </div>
                <div class="col-2 d-flex align-items-center justify-content-center">
                    <i class="bi bi-arrow-right fs-4 text-muted"></i>
                </div>
                <div class="col-5">
                    <p class="info-label mb-2">Check-Out</p>
                    <div class="p-3 bg-light rounded-4">
                        <i class="bi bi-calendar-check text-primary d-block mb-1"></i>
                        <span class="info-value">@Model.FechaFin.ToString("dd MMM, yyyy")</span>
                    </div>
                </div>
            </div>

            <div class="mt-5 d-flex flex-column flex-sm-row gap-3 justify-content-center">
                <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-primary btn-custom shadow">
                    <i class="bi bi-pencil-square me-2"></i>Modificar Reserva
                </a>
                <a asp-action="Index" class="btn btn-outline-secondary btn-custom">
                    <i class="bi bi-arrow-left me-2"></i>Regresar
                </a>
            </div>
        </div>
    </div>
</div>