@model examenwed3.Models.Reserva

@{
    ViewData["Title"] = "Nueva Reserva";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    body {
        background: linear-gradient(135deg, #e0f2fe 0%, #f0f9ff 100%);
        min-height: 100vh;
    }

    .create-container {
        animation: fadeInDown 0.6s ease-out;
        max-width: 550px;
    }

    @@keyframes fadeInDown {
        from {
            opacity: 0;
            transform: translateY(-20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .glass-card {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(10px);
        border-radius: 25px;
        box-shadow: 0 15px 35px rgba(0, 86, 179, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.2);
    }

    .header-icon {
        background: #007bff;
        color: white;
        width: 60px;
        height: 60px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 18px;
        margin: -50px auto 20px;
        box-shadow: 0 10px 20px rgba(0, 123, 255, 0.3);
    }

    .form-label {
        font-weight: 600;
        color: #0369a1;
        font-size: 0.85rem;
        margin-left: 5px;
    }

    .input-group-text {
        background-color: #f0f9ff;
        border: 2px solid #e0f2fe;
        color: #0ea5e9;
        border-radius: 12px 0 0 12px !important;
    }

    .form-control, .form-select {
        border: 2px solid #e0f2fe;
        border-radius: 0 12px 12px 0 !important;
        padding: 10px 15px;
    }

    .btn-create {
        background: linear-gradient(to right, #0ea5e9, #2563eb);
        border: none;
        border-radius: 15px;
        padding: 12px;
        font-weight: 700;
        transition: 0.3s;
    }

        .btn-create:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(37, 99, 235, 0.3);
        }

    /* Estilo para el campo de lectura del cliente */
    .form-control-readonly {
        background-color: #f8fafc !important;
        color: #64748b;
        cursor: not-allowed;
    }
</style>

<div class="container create-container py-5 mt-5">
    <div class="glass-card p-4 p-md-5">
        <div class="header-icon"><i class="bi bi-calendar-plus fs-3"></i></div>

        <div class="text-center mb-4">
            <h3 class="fw-bold text-dark">Registrar Estancia</h3>
            <p class="text-muted small">Por favor, rellena los datos para tu nueva reserva</p>
        </div>

        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="FechaInicio" class="form-label">FECHA DE ENTRADA</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-calendar-check"></i></span>
                        <input asp-for="FechaInicio" class="form-control" type="date" />
                    </div>
                    <span asp-validation-for="FechaInicio" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="FechaFin" class="form-label">FECHA DE SALIDA</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-calendar-x"></i></span>
                        <input asp-for="FechaFin" class="form-control" type="date" />
                    </div>
                    <span asp-validation-for="FechaFin" class="text-danger small"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="HotelId" class="form-label">SELECCIONAR HOTEL</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-building"></i></span>
                    <select asp-for="HotelId" class="form-select" asp-items="ViewBag.HotelId">
                        <option value="">-- Elige un hotel --</option>
                    </select>
                </div>
                <span asp-validation-for="HotelId" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label class="form-label">CLIENTE RESPONSABLE</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-person-circle"></i></span>

                    @if (User.IsInRole("Administrador"))
                    {
                        @* El Admin puede elegir de la lista *@
                        <select asp-for="UsuarioId" class="form-select" asp-items="ViewBag.UsuarioId">
                            <option value="">-- Selecciona el correo del cliente --</option>
                        </select>
                    }
                    else
                    {
                        @* El Cliente solo ve su nombre/correo (Controlador asigna el ID) *@
                        <input type="text" class="form-control form-control-readonly" value="@User.Identity.Name" readonly />
                    }
                </div>
                @if (User.IsInRole("Administrador"))
                {
                    <span asp-validation-for="UsuarioId" class="text-danger small"></span>
                }
            </div>

            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-primary btn-create text-white">
                    CONFIRMAR RESERVA <i class="bi bi-arrow-right-short ms-1"></i>
                </button>
                <a asp-action="Index" class="btn btn-link text-muted fw-bold text-decoration-none mt-2 small">
                    <i class="bi bi-arrow-left me-1"></i> Volver a la lista
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}