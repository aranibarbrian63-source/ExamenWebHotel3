@model IEnumerable<examenwed3.Models.Reserva>

@{
    ViewData["Title"] = "Mis Reservas";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h2 class="fw-bold mb-0" style="color: #00d4ff;">MIS RESERVAS</h2>
            <p class="text-light opacity-75 mb-0">Gestión de estancias exclusivas</p>
        </div>
        <div>
            @if (User.IsInRole("Administrador"))
            {
                <a asp-action="Reporte" class="btn btn-outline-info btn-sm me-2" style="border-color: #00d4ff; color: #00d4ff;">
                    <i class="fas fa-file-pdf"></i> REPORTE PDF
                </a>
            }
            <a asp-action="Create" class="btn shadow-sm px-4 fw-bold" style="background-color: #00d4ff; color: #0b1120;">
                + NUEVA RESERVA
            </a>
        </div>
    </div>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100 border-0 shadow" style="border-radius: 20px; background-color: #f8f9fa;">

                    <div class="card-header border-0 p-3 d-flex justify-content-between align-items-center" style="background-color: #e3f2fd; border-radius: 20px 20px 0 0;">
                        <span class="badge rounded-pill" style="background-color: #00d4ff; color: #0b1120;">Activa</span>
                        <small class="text-muted fw-bold">#@item.Id</small>
                    </div>

                    <div class="card-body p-4">
                        <h5 class="card-title fw-bold mb-1" style="color: #034f84;">
                            <i class="fas fa-hotel me-2"></i> @item.Hotel.Nombre
                        </h5>
                        <p class="text-muted small mb-3">
                            <i class="fas fa-map-marker-alt me-1 text-info"></i> @item.Hotel.Direccion
                        </p>

                        <div class="p-3 mb-3" style="background-color: #ffffff; border-radius: 15px; border: 1px solid #dee2e6;">
                            <div class="row text-center">
                                <div class="col-6 border-end">
                                    <label class="d-block small text-uppercase text-muted fw-bold" style="font-size: 0.7rem;">Check-in</label>
                                    <span class="fw-bold text-dark">@item.FechaInicio.ToString("dd/MM/yyyy")</span>
                                </div>
                                <div class="col-6">
                                    <label class="d-block small text-uppercase text-muted fw-bold" style="font-size: 0.7rem;">Check-out</label>
                                    <span class="fw-bold text-dark">@item.FechaFin.ToString("dd/MM/yyyy")</span>
                                </div>
                            </div>
                        </div>

                        @if (User.IsInRole("Administrador"))
                        {
                            <div class="mt-2 text-center">
                                <small class="text-muted d-block small text-uppercase">Huésped:</small>
                                <span class="fw-bold" style="color: #00d4ff;">@item.Usuario.Email</span>
                            </div>
                        }
                    </div>

                    <div class="card-footer bg-transparent border-0 p-3 pt-0">
                        <div class="d-flex justify-content-around">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-light rounded-pill px-3 shadow-sm border">
                                <i class="fas fa-info-circle text-info"></i> Ver
                            </a>

                            @if (User.IsInRole("Administrador"))
                            {
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-light rounded-pill px-3 shadow-sm border">
                                    <i class="fas fa-edit text-warning"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-light rounded-pill px-3 shadow-sm border text-danger">
                                    <i class="fas fa-times"></i>
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    /* El cuerpo mantiene el fondo azul oscuro del sistema */
    body {
        background-color: #0b1120 !important;
    }

    .card {
        transition: transform 0.2s ease-in-out;
    }

        .card:hover {
            transform: scale(1.03);
            box-shadow: 0 10px 20px rgba(0, 212, 255, 0.2) !important;
        }
</style>